{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": false,
    "outDir": "dist",
    "rootDir": ".",
    "sourceMap": true,
    "inlineSources": true,
    "declaration": false,
    "declarationMap": false,
    "incremental": true,
    "tsBuildInfoFile": "dist/.tsconfig.dist.tsbuildinfo"
  },
  "include": ["esm/**/*.ts", "esm/**/*.tsx", "types/**/*.d.ts", "types/**/*.ts"],
  "exclude": ["node_modules", "dist", "release", "tests", "tools"]
}
