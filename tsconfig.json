{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx"
  },
  "include": [
    "esm/**/*.js",
    "esm/**/*.mjs",
    "esm/**/*.ts",
    "esm/**/*.tsx",
    "types/**/*.d.ts",
    "wp_logo_data.js",
    "types/**/*.ts"
  ],
  "exclude": ["node_modules", "libs/**", "dist", "release"]
}
